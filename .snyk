# Snyk policy file — wildbitca/provider-upjet-cloudflare
# Go Crossplane/Upjet provider
version: v1.25.0

exclude:
  global:
    # Go vendored dependencies (scanned via go.mod, not SAST)
    - vendor/**

    # Build output
    - build/**
    - _output/**

    # Generated examples and code (auto-generated by Upjet)
    - examples-generated/**

    # Development scripts
    - hack/**
